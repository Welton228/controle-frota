// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// TABELAS OBRIGATÓRIAS DO NEXTAUTH (GOOGLE)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// TABELA DE USUÁRIOS (FUNCIONÁRIOS)
// ==========================================

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  phone           String?   // Para envio de alertas via WhatsApp
  zonaAtendimento String? 
  
  status          String    @default("ATIVO")
  
  // Relações
  accounts        Account[]
  sessions        Session[]
  maintenances    Maintenance[]
  mileages        MileageLog[]
  fuelLogs        FuelLog[]     
  vehicles        Vehicle[]     
  assignments     VehicleAssignment[] // Novo: Histórico de carros que este usuário dirigiu
}

// ==========================================
// TABELAS DO SISTEMA DE CONTROLE DE FROTA
// ==========================================

model Vehicle {
  id        String   @id @default(cuid())
  placa     String   @unique
  modelo    String
  ano       Int?
  status    String   @default("DISPONIVEL")
  
  // Campo para filtragem por zona (ex: 10, 28)
  zona      Int?     

  // Relação com o motorista (User)
  driverId  String?
  driver    User?    @relation(fields: [driverId], references: [id])
  
  // Histórico de atribuições (Quem dirigiu o que)
  assignments  VehicleAssignment[] 
  
  // Relações que alimentam o seu novo Dashboard de Histórico
  // O Prisma usará estas listas para calcular gastos e manutenções
  maintenances Maintenance[]
  mileages     MileageLog[]
  fuelLogs     FuelLog[]   
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==========================================
// NOVO: HISTÓRICO DE ATRIBUIÇÃO (AUDITORIA)
// ==========================================

// No seu schema.prisma
model VehicleAssignment {
  id        String    @id @default(cuid())
  vehicleId String
  userId    String
  startDate DateTime  @default(now())
  endDate   DateTime? // Se estiver null, é o motorista atual
  reason    String?   
  
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([vehicleId, endDate])
}

// ==========================================
// LOGS DE OPERAÇÃO
// ==========================================

model Maintenance {
  id             String   @id @default(cuid())
  descricao      String
  valor          Float?
  tipo           String
  kmNoMomento    Int
  
  // Datas e status
  dataManutencao DateTime @default(now())
  dataPrevisao   DateTime @default(now())
  concluido      Boolean  @default(false)
  
  // Campo mantido para retrocompatibilidade
  data           DateTime @default(now())

  // Chaves estrangeiras
  vehicleId      String
  userId         String
  
  // Relacionamentos existentes
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
  
  // Novo relacionamento: Uma manutenção pode ter vários documentos anexados (XML, PDF, Imagens)
  attachments    Document[]

  @@map("maintenance")
}

model Document {
  id            String      @id @default(cuid())
  url           String      // URL do arquivo no Supabase Storage
  fileName      String      // Nome original do arquivo
  fileType      String      // Ex: 'PDF', 'XML'
  createdAt     DateTime    @default(now())

  // Relacionamento com a manutenção
  maintenanceId String
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  @@map("document")
}

model MileageLog {
  id      String   @id @default(cuid())
  kmAtual Int
  data    DateTime @default(now())
  
  vehicleId String
  userId    String
  
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model FuelLog {
  id          String   @id @default(cuid())
  
  // Dados de abastecimento
  litros      Float    // Quantidade em litros
  valorTotal  Float    // Valor pago (Garantiremos no código que não seja negativo)
  kmNoMomento Int      // Quilometragem do veículo no ato do abastecimento
  data        DateTime @default(now()) // Data real do abastecimento
  
  // Relações com outras tabelas
  vehicleId   String
  userId      String   
  
  // Referências para o Prisma criar o relacionamento
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  // Campos de Auditoria (Essenciais para um sistema SaaS)
  createdAt   DateTime @default(now()) // Quando o registro foi criado no sistema
  updatedAt   DateTime @updatedAt      // Quando foi editado pela última vez

  // Índices para performance: Isso fará com que as buscas por veículo e usuário 
  // no Dashboard sejam instantâneas, mesmo com milhares de registros.
  @@index([vehicleId])
  @@index([userId])
}